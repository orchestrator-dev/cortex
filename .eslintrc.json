{
    "root": true,
    "parser": "@typescript-eslint/parser",
    "plugins": [
        "@typescript-eslint"
    ],
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "env": {
        "node": true,
        "es2022": true,
        "browser": true
    },
    "ignorePatterns": [
        "dist",
        "node_modules",
        "dist-types",
        ".next"
    ]
}
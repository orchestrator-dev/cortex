{
    "name": "@cortex-cms/server",
    "version": "0.2.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=../../.env src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
        "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
        "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
        "db:check": "dotenv -e ../../.env -- drizzle-kit check",
        "db:seed": "dotenv -e ../../.env -- tsx src/db/seed.ts"
    },
    "dependencies": {
        "@cortex-cms/config": "workspace:*",
        "@cortex-cms/types": "workspace:*",
        "@fastify/cookie": "^8.3.0",
        "@fastify/cors": "^9.0.1",
        "@fastify/helmet": "^11.1.1",
        "@fastify/rate-limit": "^9.1.0",
        "@fastify/sensible": "^5.5.0",
        "@fastify/swagger": "^8.14.0",
        "@fastify/swagger-ui": "^3.0.0",
        "@lucia-auth/adapter-drizzle": "^1.1.0",
        "@paralleldrive/cuid2": "^2.2.2",
        "@pothos/core": "^4.12.0",
        "@pothos/plugin-relay": "^4.7.0",
        "@pothos/plugin-validation": "^4.2.0",
        "@pothos/plugin-with-input": "^4.1.4",
        "bullmq": "^5.71.0",
        "dataloader": "^2.2.3",
        "drizzle-orm": "^0.43.1",
        "fastify": "^4.26.2",
        "fastify-plugin": "^4.5.1",
        "graphql": "^16.13.1",
        "graphql-ws": "^6.0.7",
        "graphql-yoga": "^5.18.1",
        "ioredis": "^5.4.2",
        "lucia": "^3.2.2",
        "oslo": "^1.2.1",
        "pino": "^9.14.0",
        "postgres": "^3.4.5",
        "ws": "^8.19.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/ws": "^8.18.1",
        "dotenv-cli": "^11.0.0",
        "drizzle-kit": "^0.31.0",
        "eslint": "^8.57.0",
        "pino-pretty": "^11.0.0",
        "tsx": "^4.7.1",
        "typescript": "^5.4.0",
        "vitest": "^1.4.0"
    }
}